# Normalize line endings to LF by default.
* text=auto eol=lf

# Windows-specific scripts must keep CRLF.
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files - do not normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.ttf binary
*.otf binary
*.jar binary
*.keystore binary
*.jks binary
